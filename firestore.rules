rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && request.auth.token.role == 'admin';
    }
    
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
    }
    
    match /admins/{adminId} {
      allow read: if isAdmin();
      allow write: if false; // Only created via backend
    }

    match /students/{studentId} {
      allow read: if isOwner(studentId) || isAdmin();
      // Students can edit their own profiles; Admins can do full CRUD
      allow write: if isAdmin() || isOwner(studentId); 
    }

    match /finances/{studentId} {
      allow read: if isOwner(studentId) || isAdmin();
      allow write: if isAdmin() || isOwner(studentId); // Students add payment records
    }

    match /announcements/{docId} {
      allow read: if isAuthenticated() && (resource.data.type == 'global' || resource.data.targetId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }

    match /documents/{docId} {
      // Students can read their own documents, admins can read all
      allow read: if isOwner(resource.data.studentId) || isAdmin();
      // Students can create their own documents
      allow create: if isOwner(request.resource.data.studentId) || isAdmin();
      allow update, delete: if isAdmin();
    }
  }
}
